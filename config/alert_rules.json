      "threshold": 14.4,
      "comparison": "GREATER_THAN_OR_EQUAL",
      "consecutive_breaches": 1,
      "cooldown_seconds": 300.0,
      "enabled": true
    },
    {
      "rule_id": "telemetry-export-buffer-high",
      "signal_type": "EXPORT_BUFFER_UTILIZATION",
      "severity": "WARNING",
      "threshold": 0.8,
      "comparison": "GREATER_THAN_OR_EQUAL",
      "consecutive_breaches": 3,
      "cooldown_seconds": 900.0,
      "enabled": true
    }
  ]
}
